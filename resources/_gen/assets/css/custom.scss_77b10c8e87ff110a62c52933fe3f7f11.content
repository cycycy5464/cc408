:root{--bg-primary:#0a0e14;--bg-secondary:#121620;--bg-card:#181e28;--bg-hover:#1e2633;--accent:#39bae6;--accent-glow:rgba(57,186,230,0.25);--accent2:#95e6cb;--color-ds:#39bae6;--color-co:#ff8f40;--color-os:#a277ff;--color-cn:#95e6cb;--text-primary:#e2e8f0;--text-secondary:#8899a9;--text-muted:#5d6b7a;--border-color:#232a35;--border-light:#2a3240;--font-display:"Inter","PingFang SC","Microsoft YaHei",sans-serif;--font-body:"Noto Sans SC","Inter",sans-serif;--font-mono:"JetBrains Mono","Fira Code",monospace;--fs-hero:clamp(2.4rem,6vw,4.5rem);--fs-h1:clamp(1.8rem,4vw,2.8rem);--fs-h2:1.6rem;--fs-h3:1.25rem;--fs-body:1rem;--fs-sm:0.875rem;--fs-xs:0.75rem;--space-section:4rem;--space-block:2rem;--space-card:1.5rem;--radius-sm:6px;--radius-md:10px;--radius-lg:16px;--shadow-glow:0 0 24px rgba(57,186,230,0.15);--shadow-card:0 2px 12px rgba(0,0,0,0.25)}*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{font-family:var(--font-body);font-size:var(--fs-body);line-height:1.75;color:var(--text-primary);background:var(--bg-primary);-webkit-font-smoothing:antialiased}h1,h2,h3,h4,h5,h6{font-family:var(--font-display);font-weight:700;line-height:1.25;letter-spacing:-.01em}h1{font-size:var(--fs-h1);margin-bottom:1.5rem}h2{font-size:var(--fs-h2);margin-top:3rem;margin-bottom:1rem;padding-bottom:.5rem;border-bottom:1px solid var(--border-light);letter-spacing:-.005em}h3{font-size:var(--fs-h3);margin-top:2rem;margin-bottom:.75rem}p{margin-bottom:1.25rem}a{color:var(--accent);text-decoration:none;transition:color .2s}a:hover{color:var(--accent2)}.skip-link{position:absolute;top:-100px;left:1rem;z-index:10000;padding:.5rem 1rem;background:var(--accent);color:var(--bg-primary);border-radius:var(--radius-sm);font-weight:600}.skip-link:focus{top:10px}.gradient-text{background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}.navbar{position:fixed;top:0;left:0;right:0;z-index:1000;height:60px;display:flex;align-items:center;padding:0 1.5rem;background:rgba(18,22,32,.75);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,6%)}.navbar-brand{font-family:var(--font-display);font-weight:800;font-size:1.3rem;color:var(--accent);text-decoration:none;margin-right:2.5rem;letter-spacing:-.02em}.navbar-links{display:flex;gap:1.5rem;align-items:center}.navbar-links a{color:var(--text-secondary);text-decoration:none;font-size:var(--fs-sm);font-weight:500;position:relative;padding:.3rem 0;transition:color .2s}.navbar-links a:hover{color:var(--text-primary)}.navbar-links a.active{color:var(--accent)}.navbar-links a.active::after{content:"";position:absolute;bottom:-6px;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:1px}.navbar-right{margin-left:auto}.navbar-right a{color:var(--text-muted);text-decoration:none;font-size:var(--fs-xs);transition:color .2s}.navbar-right a:hover{color:var(--text-secondary)}.navbar-toggle{display:none;background:0 0;border:none;color:var(--text-primary);font-size:1.5rem;cursor:pointer}.hero{text-align:center;padding:6rem 2rem 4rem;position:relative;overflow:hidden;min-height:70vh;display:flex;flex-direction:column;justify-content:center;align-items:center}.hero::before{content:"";position:absolute;inset:0;background:linear-gradient(rgba(57,186,230,3%) 1px,transparent 1px),linear-gradient(90deg,rgba(57,186,230,3%) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 70% 60% at 50% 40%,#000 30%,transparent 70%)}.hero::after{content:"";position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(57,186,230,8%) 0%,transparent 60%);pointer-events:none}.hero-content{position:relative;z-index:1}.hero-title{font-family:var(--font-display);font-size:var(--fs-hero);font-weight:900;margin-bottom:1rem;letter-spacing:-.03em;line-height:1.1}.hero-subtitle{font-size:1.2rem;color:var(--text-secondary);margin-bottom:2.5rem;max-width:500px;margin-left:auto;margin-right:auto}.hero-actions{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center}.btn{display:inline-flex;align-items:center;gap:.4rem;padding:.6rem 1.6rem;border-radius:var(--radius-md);font-family:var(--font-display);font-weight:600;font-size:var(--fs-sm);transition:all .25s;cursor:pointer;text-decoration:none;border:none}.btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:var(--bg-primary)}.btn-primary:hover{box-shadow:var(--shadow-glow);transform:translateY(-1px);color:var(--bg-primary)}.btn-outline{border:1.5px solid var(--border-light);color:var(--text-primary);background:rgba(255,255,255,3%)}.btn-outline:hover{border-color:var(--accent);box-shadow:var(--shadow-glow);transform:translateY(-1px);color:var(--accent);background:rgba(57,186,230,6%)}.btn-ghost{color:var(--text-secondary);background:0 0}.btn-ghost:hover{color:var(--text-primary);background:var(--bg-hover)}.card{background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:var(--space-card);transition:all .3s;text-decoration:none;color:var(--text-primary);display:block;position:relative;overflow:hidden}.card::before{content:"";position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(57,186,230,.3),transparent);opacity:0;transition:opacity .3s}.card:hover{border-color:var(--accent);box-shadow:var(--shadow-glow);transform:translateY(-2px)}.card:hover::before{opacity:1}.card-link{text-decoration:none;color:inherit;display:block}.hero-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;max-width:900px;margin:0 auto;padding:0 2rem 4rem}.hero-card{text-align:center;padding:2rem 1.5rem}.hero-card-icon{font-size:2.5rem;margin-bottom:.75rem;transition:transform .3s}.hero-card:hover .hero-card-icon{transform:scale(1.1)}.hero-card-title{font-family:var(--font-display);font-weight:700;font-size:1.1rem;margin-bottom:.4rem}.hero-card-desc{color:var(--text-muted);font-size:var(--fs-sm)}.hero-card.ds .hero-card-icon{color:var(--color-ds)}.hero-card.co .hero-card-icon{color:var(--color-co)}.docs-layout{display:flex;min-height:calc(100vh - 70px)}.side-nav{width:260px;flex-shrink:0;background:var(--bg-secondary);border-right:1px solid var(--border-color);overflow-y:auto;height:calc(100vh - 70px);position:sticky;top:70px}.side-nav-link{display:block;padding:.45rem 1.5rem .45rem 2.5rem;font-size:var(--fs-sm);color:var(--text-secondary);transition:all .15s;border-left:2px solid transparent;text-decoration:none}.side-nav-link:hover{color:var(--text-primary);background:var(--bg-hover);border-left-color:var(--border-light)}.side-nav-link.active{color:var(--accent);background:rgba(57,186,230,6%);border-left-color:var(--accent);font-weight:500}.content-area{flex:1;max-width:820px;margin:0 auto;padding:2rem}.content-area-wide{max-width:960px}pre{background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-md);padding:1.25rem;overflow-x:auto;margin:1rem 0;position:relative}pre::after{content:"";position:absolute;top:0;left:1rem;right:1rem;height:1px;background:linear-gradient(90deg,transparent,rgba(57,186,230,.15),transparent)}pre code{font-family:var(--font-mono);font-size:.875rem;line-height:1.6;color:var(--text-primary)}:not(pre)>code{background:rgba(57,186,230,.1);color:var(--accent);padding:.15em .4em;border-radius:4px;font-size:.9em}.tag{display:inline-flex;align-items:center;padding:.2em .7em;font-size:var(--fs-xs);border-radius:4px;background:rgba(57,186,230,.1);color:var(--accent);margin-right:.4rem;font-weight:500;border:1px solid rgba(57,186,230,.15)}.tag:hover{background:rgba(57,186,230,.2)}.tag-accent{background:rgba(149,230,203,.1);color:var(--accent2);border-color:rgba(149,230,203,.15)}.tag-warm{background:rgba(255,143,64,.1);color:var(--color-co);border-color:rgba(255,143,64,.15)}.tag-purple{background:rgba(162,119,255,.1);color:var(--color-os);border-color:rgba(162,119,255,.15)}.diff-star{color:#f0c040}.diff-star-empty{color:var(--text-muted)}.filter-bar{display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;padding:1rem 1.25rem;background:var(--bg-secondary);border:1px solid var(--border-color);border-radius:var(--radius-md);margin:1.5rem 0}.filter-bar select,.filter-bar input{padding:.45rem .75rem;background:var(--bg-card);color:var(--text-primary);border:1px solid var(--border-color);border-radius:var(--radius-sm);font-size:var(--fs-sm);font-family:var(--font-body)}.filter-bar input{flex:1;min-width:180px}.filter-bar select:focus,.filter-bar input:focus{outline:none;border-color:var(--accent)}.meta-row{display:flex;gap:1rem;flex-wrap:wrap;align-items:center;font-size:var(--fs-sm);color:var(--text-secondary);margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid var(--border-color)}details.card{cursor:pointer}details summary{font-weight:600;color:var(--accent);padding:.5rem 0;list-style:none}details summary::-webkit-details-marker{display:none}details[open] summary{margin-bottom:1rem;border-bottom:1px solid var(--border-color);padding-bottom:.75rem}.info-panel{position:fixed;right:1.5rem;top:90px;width:280px;z-index:100;background:var(--bg-card);border:1px solid var(--border-color);border-radius:var(--radius-lg);padding:1.5rem;display:none;box-shadow:var(--shadow-card)}.info-panel h3{margin-top:0;font-size:1.1rem}.info-panel-close{position:absolute;top:.5rem;right:.5rem;background:0 0;border:none;color:var(--text-secondary);cursor:pointer;font-size:1.2rem}.site-footer{padding:2rem;text-align:center;color:var(--text-muted);font-size:var(--fs-xs);border-top:1px solid var(--border-color);background:var(--bg-secondary);letter-spacing:.02em}.watermark-layer{position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:.04;background-repeat:repeat;background-size:300px 300px}.graph-page{min-height:calc(100vh - 70px);background:var(--bg-primary)}.graph-search{position:absolute;top:90px;left:1.5rem;z-index:10}.graph-search input{padding:.5rem 1rem;background:var(--bg-card);color:var(--text-primary);border:1px solid var(--border-color);border-radius:var(--radius-md);width:250px;font-size:var(--fs-sm)}.graph-container{width:100%;height:70vh;position:relative}@media(max-width:768px){.navbar{padding:0 1rem}.navbar-links{display:none;position:absolute;top:60px;left:0;right:0;background:var(--bg-secondary);flex-direction:column;padding:1rem;gap:1rem;border-bottom:1px solid var(--border-color)}.navbar-links.open{display:flex}.navbar-toggle{display:block}.navbar-links a.active::after{display:none}.docs-layout{flex-direction:column}.side-nav{width:100%;height:auto;position:static;border-right:none;border-bottom:1px solid var(--border-color);padding:.75rem}.content-area{padding:1rem;max-width:100%}.hero{padding:4rem 1rem 2rem;min-height:auto}.hero-cards{padding:0 1rem 2rem;grid-template-columns:1fr}}@media print{.navbar,.side-nav,.watermark-layer,.skip-link{display:none!important}body{background:#fff;color:#000}a{color:#000;text-decoration:underline}.content-area{max-width:100%}}